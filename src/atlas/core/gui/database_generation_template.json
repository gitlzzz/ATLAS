  "generation": {
    "generate_type": {
      "key_name": "generate_type",
      "default_value": [
        "bulk",
        "surface"
      ],
      "type": "list",
      "description": "Type of structures to generate. Options: 'bulk', 'surface', 'cluster'",
      "optional": false
    },
    "bulk": {
      "num_struct": {
        "key_name": "num_struct",
        "default_value": 25,
        "type": "int",
        "description": "Number of structures to generate",
        "optional": false
      },
      "num_repeat": {
        "key_name": "num_repeat",
        "default_value": 5,
        "type": "int",
        "description": "Number of repeats for each structure",
        "optional": false
      },
      "supercell_max_idx": {
        "key_name": "supercell_max_idx",
        "default_value": 2,
        "type": "int",
        "description": "Maximum Miller index for the bulk supercells",
        "optional": false
      }
    },
    "surface": {
      "min_miller_index": {
        "key_name": "min_miller_index",
        "default_value": 1,
        "type": "int",
        "description": "Lowest miller index used to generate structures",
        "optional": false
      },
      "max_miller_index": {
        "key_name": "max_miller_index",
        "default_value": 3,
        "type": "int",
        "description": "Highest index for the supercell generation. Supercells will be created in the x and y directions",
        "optional": false
      },
      "min_slab_size_ang": {
        "key_name": "min_slab_size_ang",
        "default_value": 7,
        "type": "float",
        "description": "Minimum slab size in Angstrom",
        "optional": false
      },
      "min_vacuum_size_ang": {
        "key_name": "min_vacuum_size_ang",
        "default_value": 12,
        "type": "float",
        "description": "Minimum vacuum size in Angstrom",
        "optional": false
      },
      "get_supercells": {
        "key_name": "get_supercells",
