{
  "database": {
    "database_name": {
      "key_name": "database_name",
      "default_value": "cu_only_new",
      "type": "str",
      "description": "Name of the database to be used as filename and for internal reference",
      "optional": false
    },
    "min_num_atoms": {
      "key_name": "min_num_atoms",
      "default_value": 24,
      "type": "int",
      "description": "minimum number of atoms in the structure",
      "optional": false
    },
    "max_num_atoms": {
      "key_name": "max_num_atoms",
      "default_value": 256,
      "type": "int",
      "description": "maximum number of atoms in the structure",
      "optional": false
    },
    "min_cell_size": {
      "key_name": "min_cell_size",
      "default_value": 5.0,
      "type": "float",
      "description": "minimum cell size in Angstrom",
      "optional": false
    },
    "relax_struct_path": {
      "key_name": "relax_struct_path",
      "default_value": "",
      "type": "str",
      "description": "Path to a folder containing DFT optimized structures",
      "optional": true
    },
    "database_path": {
      "key_name": "database_path",
      "default_value": "",
      "type": "str",
      "description": "Path for the final database",
      "optional": false
    },
    "rng_seed": {
      "key_name": "rng_seed",
      "default_value": 16122024,
      "type": "int",
      "description": "Value for the RNG seed",
      "optional": true
    },
    "overwrite_db": {
      "key_name": "overwrite_db",
      "default_value": false,
      "type": "bool",
      "description": "Allow database overwrite. Default is false. If false, and the database exists, the new database name and folder will include a timestamp.",
      "optional": true
    },
    "composition": {
      "size": {
        "key_name": "size",
        "default_value": 2000,
        "type": "int",
        "description": "Maximum number of structures to generate for the database",
        "optional": false
      },
      "ratios": {
        "bulk": {
          "key_name": "bulk",
          "default_value": 0.5,
          "type": "float",
          "description": "Fraction of structures that will be bulk",
          "optional": false
        },
        "surface": {
          "key_name": "surface",
          "default_value": 0.5,
          "type": "float",
          "description": "Fraction of structures that will be surfaces",
          "optional": false
        },
        "cluster": {
          "key_name": "cluster",
          "default_value": 0.0,
          "type": "float",
          "description": "Fraction of structures that will be clusters",
          "optional": false
        }
      }
    },
    "plot_db": {
      "show": {
        "key_name": "show",
        "default_value": true,
        "type": "bool",
        "description": "Display database with phase diagram after creation",
        "optional": true
      },
      "format": {
        "key_name": "format",
        "default_value": "png",
        "type": "str",
        "description": "Format for the figure, such as 'png' or 'svg'. Default is 'png'.",
        "optional": true
      },
      "rc_params": {
        "font.family": {
          "key_name": "font.family",
          "default_value": "DejaVu Sans",
          "type": "str",
          "description": "Display options which follow the RCParams of matplotlib",
          "optional": false
        },
        "font.size": {
          "key_name": "font.size",
          "default_value": 12,
          "type": "int",
          "description": "Display options which follow the RCParams of matplotlib",
          "optional": false
        }
      }
    },
    "show_db_ase": {
      "show": {
        "key_name": "show",
        "default_value": true,
        "type": "bool",
        "description": "Display database with ASE GUI after creation",
        "optional": true
      }
    },
    "export": {
      "export": {
        "key_name": "export",
        "default_value": true,
        "type": "bool",
        "description": "Export format for the database, such as 'extxyz'. The format must be supported by ASE, see: https://wiki.fysik.dtu.dk/ase/ase/io/io.html#ase.io.read",
        "optional": false
      },
      "format": {
        "key_name": "format",
        "default_value": "extxyz",
        "type": "str",
        "description": "The format must be supported by ASE",
        "optional": false
      },
      "file_path": {
        "key_name": "file_path",
        "default_value": "",
        "type": "str",
        "description": "",
        "optional": false
      },
      "file_name": {
        "key_name": "file_name",
        "default_value": "cu_db_all_phases",
        "type": "str",
        "description": "",
        "optional": false
      }
    }
  },
